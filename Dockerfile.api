FROM python:3.13-slim

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN pip install --no-cache-dir uvicorn fastapi pandas pyarrow openpyxl pyyaml python-dotenv

COPY api/ api/
COPY config/ config/
COPY src/ src/
COPY data/processed/ data/processed/

EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]

# =============================================================
# Environment variable template for my-project
# Copy to .env and fill in values before running the pipeline.
# Never commit .env — it is in .gitignore.
# =============================================================

# LSEG Workspace credentials (required for lseg.py ingestion)
# See docs/LSEG_SETUP.md for setup instructions.
LSEG_APP_KEY=your_app_key_here

# SEC EDGAR API — required for edgar.py ingestion (Phase 8)
# SEC requires a User-Agent email for all EDGAR API calls.
# Any valid email works — SEC uses this for rate limit notifications only.
EDGAR_USER_EMAIL=your.email@example.com
